APP_NAME=Flowdesk
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=mailersend_failover
MAIL_TRANSACTIONAL_MAILER=mailersend_failover
MAIL_HOST=smtp.mailersend.net
MAIL_PORT=587
MAIL_USERNAME=your-mailersend-smtp-username
MAIL_PASSWORD=your-mailersend-smtp-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@your-verified-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional Resend SMTP fallback profile
# MAIL_MAILER=resend_failover
# MAIL_TRANSACTIONAL_MAILER=resend_failover
RESEND_API_KEY=your-resend-api-key
RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=587
RESEND_SMTP_ENCRYPTION=tls
RESEND_SMTP_USERNAME=resend

# Default MailerSend transactional email setup
MAILERSEND_API_KEY=your-mailersend-api-key
MAILERSEND_DOMAIN=your-verified-domain.com
MAILERSEND_WEBHOOK_SECRET=your-mailersend-webhook-secret
MAILERSEND_SMTP_HOST=smtp.mailersend.net
MAILERSEND_SMTP_PORT=587
MAILERSEND_SMTP_ENCRYPTION=tls
MAILERSEND_SMTP_USERNAME=your-mailersend-smtp-username
MAILERSEND_SMTP_PASSWORD=your-mailersend-smtp-password

# Communication delivery mode: inline or queue
FLOWDESK_COMM_DELIVERY_MODE=inline

SMS_PROVIDER=placeholder
TERMII_API_KEY=
TERMII_SENDER_ID=
TERMII_CHANNEL=generic
TERMII_SMS_URL=https://api.ng.termii.com/api/sms/send

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

REQUEST_STEP_DUE_HOURS=24
REQUEST_REMINDER_HOURS_BEFORE_DUE=6
REQUEST_ESCALATION_GRACE_HOURS=6

FLOWDESK_RATE_LIMIT_EXECUTION_WEBHOOKS_PER_MINUTE=60
FLOWDESK_RATE_LIMIT_TENANT_DOWNLOADS_PER_MINUTE=120
FLOWDESK_RATE_LIMIT_TENANT_EXPORTS_PER_MINUTE=40

# -------------------------------------------------------------------
# Execution Rails — Payment Providers
# Set the default provider new tenants are assigned to before go-live.
# Flip individual tenants to a real provider via Platform → Tenant Execution Mode.
# -------------------------------------------------------------------

FLOWDESK_EXECUTION_FALLBACK_PROVIDER=null
FLOWDESK_RAILS_DEFAULT_PROVIDER=manual_ops
FLOWDESK_RAILS_PILOT_COMPANY_SLUGS=
FLOWDESK_RAILS_GO_LIVE_COMPANY_SLUGS=
FLOWDESK_RAILS_ALLOW_EXTERNAL_WITHOUT_PILOT=false

# Paystack — https://dashboard.paystack.com/#/settings/developer
FLOWDESK_PAYSTACK_BASE_URL=https://api.paystack.co
FLOWDESK_PAYSTACK_SECRET_KEY=
FLOWDESK_PAYSTACK_WEBHOOK_SECRET=
FLOWDESK_PAYSTACK_SANDBOX_BASE_URL=https://api.paystack.co
FLOWDESK_PAYSTACK_SANDBOX_SECRET_KEY=
FLOWDESK_PAYSTACK_SANDBOX_WEBHOOK_SECRET=

# Flutterwave — https://developer.flutterwave.com/docs
FLOWDESK_FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLOWDESK_FLUTTERWAVE_SECRET_KEY=
FLOWDESK_FLUTTERWAVE_WEBHOOK_SECRET_HASH=
FLOWDESK_FLUTTERWAVE_SANDBOX_BASE_URL=https://api.flutterwave.com/v3
FLOWDESK_FLUTTERWAVE_SANDBOX_SECRET_KEY=
FLOWDESK_FLUTTERWAVE_SANDBOX_WEBHOOK_SECRET_HASH=
FLOWDESK_FLUTTERWAVE_REDIRECT_URL=

# Mono — https://app.mono.co/apps (Open Banking + Disbursements + DirectPay)
# sk_live_... for production, sk_test_... for sandbox
# Webhook header verified: mono-webhook-secret (HMAC-SHA512)
# Connect webhook URL: https://your-domain.com/webhooks/execution/mono
FLOWDESK_MONO_BASE_URL=https://api.withmono.com
FLOWDESK_MONO_SECRET_KEY=
FLOWDESK_MONO_WEBHOOK_SECRET=
FLOWDESK_MONO_SANDBOX_BASE_URL=https://api.withmono.com
FLOWDESK_MONO_SANDBOX_SECRET_KEY=
FLOWDESK_MONO_SANDBOX_WEBHOOK_SECRET=
FLOWDESK_MONO_REDIRECT_URL=

# Subscription / plan billing amounts (in major currency units, e.g. NGN)
FLOWDESK_BILLING_DEFAULT_CURRENCY=NGN
FLOWDESK_PLAN_AMOUNT_PILOT=0
FLOWDESK_PLAN_AMOUNT_GROWTH=0
FLOWDESK_PLAN_AMOUNT_BUSINESS=0
FLOWDESK_PLAN_AMOUNT_ENTERPRISE=0

FLOWDESK_EXECUTION_OPS_AUTO_RECOVERY_ENABLED=true
FLOWDESK_EXECUTION_OPS_AUTO_RECOVERY_OLDER_THAN_MINUTES=30
FLOWDESK_EXECUTION_OPS_AUTO_RECOVERY_MAX_PER_PIPELINE=200
FLOWDESK_EXECUTION_OPS_AUTO_RECOVERY_COOLDOWN_MINUTES=15

FLOWDESK_CORRELATION_HEADER=X-Correlation-ID
FLOWDESK_ERROR_TRACKING_ENABLED=true
FLOWDESK_ERROR_TRACKING_ENVIRONMENTS=production
FLOWDESK_ERROR_TRACKING_LOG_CHANNEL=error-tracking
FLOWDESK_ERROR_TRACKING_WEBHOOK_URL=
FLOWDESK_ERROR_TRACKING_TOKEN=
FLOWDESK_ERROR_TRACKING_TIMEOUT_SECONDS=3
FLOWDESK_PRODUCTION_VALIDATION_FAIL_FAST=false
FLOWDESK_SCHEDULER_HEARTBEAT_CACHE_KEY=flowdesk:ops:scheduler-heartbeat-at
