APP_NAME=Flowdesk
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SMS_PROVIDER=placeholder
TERMII_API_KEY=
TERMII_SENDER_ID=
TERMII_CHANNEL=generic
TERMII_SMS_URL=https://api.ng.termii.com/api/sms/send

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

REQUEST_STEP_DUE_HOURS=24
REQUEST_REMINDER_HOURS_BEFORE_DUE=6
REQUEST_ESCALATION_GRACE_HOURS=6

FLOWDESK_RATE_LIMIT_EXECUTION_WEBHOOKS_PER_MINUTE=60
FLOWDESK_RATE_LIMIT_TENANT_DOWNLOADS_PER_MINUTE=120
FLOWDESK_RATE_LIMIT_TENANT_EXPORTS_PER_MINUTE=40

FLOWDESK_EXECUTION_OPS_AUTO_RECOVERY_ENABLED=true
FLOWDESK_EXECUTION_OPS_AUTO_RECOVERY_OLDER_THAN_MINUTES=30
FLOWDESK_EXECUTION_OPS_AUTO_RECOVERY_MAX_PER_PIPELINE=200
FLOWDESK_EXECUTION_OPS_AUTO_RECOVERY_COOLDOWN_MINUTES=15

FLOWDESK_CORRELATION_HEADER=X-Correlation-ID
FLOWDESK_ERROR_TRACKING_ENABLED=true
FLOWDESK_ERROR_TRACKING_ENVIRONMENTS=production
FLOWDESK_ERROR_TRACKING_LOG_CHANNEL=error-tracking
FLOWDESK_ERROR_TRACKING_WEBHOOK_URL=
FLOWDESK_ERROR_TRACKING_TOKEN=
FLOWDESK_ERROR_TRACKING_TIMEOUT_SECONDS=3
FLOWDESK_PRODUCTION_VALIDATION_FAIL_FAST=false
FLOWDESK_SCHEDULER_HEARTBEAT_CACHE_KEY=flowdesk:ops:scheduler-heartbeat-at
